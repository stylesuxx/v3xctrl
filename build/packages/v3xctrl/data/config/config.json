{
  "video": {
    "autostart": false,
    "testSource": true,
    "resolution": "1280x720@30",
    "bitrate": 1800000,
    "mtu": 1400,
    "record": {
      "autostart": false,
      "path": "/data/recordings"
    },
    "iFrame": {
      "period": 15,
      "autoAdjust": true,
      "maxBytes": 25600
    },
    "qp": {
      "min": 20,
      "max": 51
    },
    "h264Profile": "high"
  },
  "camera": {
    "enableHdr": false,
    "afMode": 0,
    "lensPosition": 0,
    "analogueGainMode": 0,
    "analogueGain": 1,
    "exposureTimeMode": 0,
    "exposureTime": 32000,
    "sensorMode": "0x0",
    "brightness": 0.0,
    "contrast": 1.0,
    "saturation": 1.0,
    "sharpness": 0.0
  },
  "control": {
    "autostart": true,
    "failsafeTimeout": 150,
    "throttle": {
      "min": 1000,
      "max": 2000,
      "failsafe": 1500,
      "scaleForward": 100,
      "scaleReverse": 100,
      "minForward": 0,
      "minReverse": 0,
      "idle": 1500
    },
    "steering": {
      "min": 1000,
      "max": 2000,
      "failsafe": 1500,
      "trim": 0,
      "scale": 100,
      "invert": false
    },
    "pwm": {
      "throttle": 0,
      "steering": 1
    }
  },
  "telemetry": {
    "battery": {
      "i2cAddress": "0x40",
      "minVoltage": 3500,
      "warnVoltage": 3700,
      "maxVoltage": 4200,
      "shuntResistance": 50,
      "maxExpectedCurrent": 10
    },
    "gps": {
      "path": "/dev/serial0",
      "protocol": "ublox",
      "rateHz": 5
    }
  },
  "viewer": {
    "mode": "direct",
    "transport": "udp",
    "direct": {
      "host": "192.168.1.100"
    },
    "relay": {
      "host": "relay.v3xctrl.com:8888",
      "sessionId": "test123"
    },
    "ports": {
      "control": 16386,
      "video": 16384
    }
  },
  "network": {
    "routing": "wlan",
    "wifi": {
      "mode": "client"
    },
    "modem": {
      "model": "generic",
      "path": "/dev/eigencomm-at",
      "limitBands": false,
      "allowedBands": []
    },
    "extras": {
      "samba": false,
      "reverseShellUrl": ""
    }
